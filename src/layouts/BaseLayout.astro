---
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';

interface Props {
  title: string;
  description?: string;
  image?: string;
  type?: 'website' | 'article';
  canonicalUrl?: string;
}

const { 
  title, 
  description = "Your trusted source for medical information and health insights.",
  image = "/favicon.svg", // Fallback, could be a better default OG image
  type = "website",
  canonicalUrl = Astro.url.href
} = Astro.props;
---

<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>{title} | MedBlog</title>
  <meta name="description" content={description}>
  <link rel="icon" type="image/svg+xml" href="/favicon.svg">
  
  <!-- Canonical URL -->
  <link rel="canonical" href={canonicalUrl} />

  <!-- Open Graph / Facebook -->
  <meta property="og:type" content={type} />
  <meta property="og:url" content={canonicalUrl} />
  <meta property="og:title" content={`${title} | MedBlog`} />
  <meta property="og:description" content={description} />
  <meta property="og:image" content={new URL(image, Astro.url)} />

  <!-- Twitter -->
  <meta property="twitter:card" content="summary_large_image" />
  <meta property="twitter:url" content={canonicalUrl} />
  <meta property="twitter:title" content={`${title} | MedBlog`} />
  <meta property="twitter:description" content={description} />
  <meta property="twitter:image" content={new URL(image, Astro.url)} />
</head>
<body>
  <div class="wrapper">
    <slot name="header">
      <Header />
    </slot>
    
    <main>
      <slot />
    </main>
    
    <slot name="footer">
      <Footer />
    </slot>
  </div>
</body>
</html>

<style is:global>
  :root {
    --brand-blue: #2563eb;
    --brand-blue-hover: #1d4ed8;
    --brand-blue-light: #dbeafe;
    --brand-purple: #764ba2;
    
    --bg-color: #f9fafb;
    --text-primary: #1a1a1a;
    --text-body: #333333;
    --text-muted: #666666;
  }

  * {
    margin: 0;
    padding: 0;
    box-sizing: border-box;
  }
  
  body {
    font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, Oxygen, Ubuntu, Cantarell, 'Open Sans', 'Helvetica Neue', sans-serif;
    line-height: 1.6;
    color: var(--text-body);
    background: var(--bg-color);
  }
  
  h1, h2, h3, h4, h5, h6 {
    color: var(--text-primary);
  }
  
  .wrapper {
    display: flex;
    flex-direction: column;
    min-height: 100vh;
  }
  
  main {
    flex: 1;
  }
  
  img {
    max-width: 100%;
    height: auto;
  }
  
  a {
    color: var(--brand-blue);
    text-decoration: none;
  }
  
  a:hover {
    text-decoration: underline;
  }
</style>
