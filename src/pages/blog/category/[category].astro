---
import BaseLayout from '../../../layouts/BaseLayout.astro';
import BlogCard from '../../../components/BlogCard.astro';
import { getPosts } from '../../../lib/queries';
import { urlFor } from '../../../lib/sanity';
import type { SanityPost } from '../../../lib/types';

export async function getStaticPaths() {
  const posts = await getPosts();

  // Extract unique categories
  const categories = [
    ...new Set(
      posts
        .flatMap((post) => post.categories || [])
        .filter(Boolean)
        .map((cat) => cat.title)
    ),
  ];

  // Map each category to a route
  return categories.map((category) => {
    // Determine a URL-friendly slug
    const categorySlug = category?.toLowerCase().replace(/\s+/g, '-') || 'general';

    // Filter posts for this specific category
    const filteredPosts = posts.filter((post) => {
      const postCategories = post.categories?.map((c) => c.title) || [];
      return postCategories.includes(category!);
    });

    return {
      params: { category: categorySlug },
      props: {
        categoryName: category,
        posts: filteredPosts,
        allCategories: categories, // pass all categories so we can render the navigation pills
      },
    };
  });
}

// Props passed from getStaticPaths
const { categoryName, posts, allCategories } = Astro.props;
const { category } = Astro.params;
---

<BaseLayout 
  title={`${categoryName} Articles - MedBlog`} 
  description={`Browse our collection of evidence-based medical articles categorized under ${categoryName}.`}
>
  <div class="blog-page">
    <div class="blog-header">
      <div class="container">
        <h1>{categoryName} Articles</h1>
        <p>Evidence-based health information and medical insights from healthcare professionals</p>
      </div>
    </div>
    
    <div class="blog-content">
      <div class="container">
        <!-- Category Filter -->
        <div class="category-filter">
          <h2>Categories</h2>
          <div class="category-pills">
            <a href="/blog" class="category-pill">All Articles</a>
            {allCategories.map((cat) => {
              const catSlug = cat?.toLowerCase().replace(/\s+/g, '-');
              const isActive = cat === categoryName;
              return (
                <a 
                  href={`/blog/category/${catSlug}`} 
                  class={`category-pill ${isActive ? 'active' : ''}`}
                >
                  {cat}
                </a>
              );
            })}
          </div>
        </div>
        
        <!-- Blog Posts Grid -->
        <div class="posts-grid" id="posts-grid">
          {posts.map((post: SanityPost) => (
            <div class="post-item">
              <BlogCard
                slug={post.slug.current}
                title={post.title}
                description={post.excerpt || ''}
                pubDate={post.publishedAt ? new Date(post.publishedAt) : new Date()}
                category={post.categories?.[0]?.title || 'General'}
                image={post.mainImage?.asset ? urlFor(post.mainImage).width(400).format('webp').quality(80).url() : undefined}
              />
            </div>
          ))}
        </div>
        
        {posts.length === 0 && (
          <div class="no-posts">
            <p>No articles found for this category. Check back soon for new content!</p>
          </div>
        )}
      </div>
    </div>
  </div>
</BaseLayout>

<style>
  .container {
    max-width: 1200px;
    margin: 0 auto;
    padding: 0 2rem;
  }
  
  .blog-header {
    background: linear-gradient(135deg, var(--brand-blue) 0%, var(--brand-purple) 100%);
    color: white;
    padding: 4rem 0;
    text-align: center;
  }
  
  .blog-header h1 {
    font-size: 3rem;
    font-weight: 700;
    margin-bottom: 1rem;
  }
  
  .blog-header p {
    font-size: 1.25rem;
    opacity: 0.95;
    max-width: 600px;
    margin: 0 auto;
  }
  
  .blog-content {
    padding: 3rem 0;
  }
  
  .category-filter {
    margin-bottom: 3rem;
  }
  
  .category-filter h2 {
    font-size: 1.25rem;
    font-weight: 600;
    color: #1a1a1a;
    margin-bottom: 1rem;
  }
  
  .category-pills {
    display: flex;
    flex-wrap: wrap;
    gap: 0.75rem;
  }
  
  .category-pill {
    padding: 0.625rem 1.25rem;
    background: white;
    border: 2px solid #e5e7eb;
    border-radius: 24px;
    font-weight: 500;
    color: var(--text-muted);
    cursor: pointer;
    transition: all 0.2s;
    text-transform: capitalize;
    text-decoration: none;
    display: inline-block;
  }
  
  .category-pill:hover {
    border-color: var(--brand-blue);
    color: var(--brand-blue);
    text-decoration: none;
  }
  
  .category-pill.active {
    background: var(--brand-blue);
    border-color: var(--brand-blue);
    color: white;
  }
  
  .posts-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(320px, 1fr));
    gap: 2rem;
  }
  
  .post-item {
    transition: opacity 0.3s;
  }
  
  .no-posts {
    text-align: center;
    padding: 4rem 2rem;
    color: #666;
    font-size: 1.125rem;
  }
  
  @media (max-width: 768px) {
    .blog-header {
      padding: 3rem 0;
    }
    
    .blog-header h1 {
      font-size: 2rem;
    }
    
    .blog-header p {
      font-size: 1.125rem;
    }
    
    .posts-grid {
      grid-template-columns: 1fr;
    }
  }
</style>
